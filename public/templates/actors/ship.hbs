<form class="{{cssClass}} flexcol" autocomplete="off">
  <div class="theah-layout">

    {{!-- ===================== Identity rail ===================== --}}
    <aside class="identity-rail">
      <span class="edge"></span>

      <div class="portrait">
        <img class="profile-img" src="{{img}}" data-edit="img" title="{{name}}" alt="{{name}}" />
        <svg class="corner tl" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner tr" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner bl" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner br" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
      </div>

      <div class="nameplate">
        <input class="name" type="text" name="name" value="{{name}}" placeholder="{{localize 'SVNSEA2E.ActorName'}}" />
        <input class="epithet" type="text" name="system.class" value="{{shipClass}}" placeholder="{{localize 'SVNSEA2E.ClassPlaceholder'}}" />
      </div>

      <div class="filet" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2v14M8 6h8M6 16a6 6 0 0 0 12 0"/><circle cx="12" cy="4" r="1.6"/></svg>
      </div>

      <dl class="meta">
        <dt data-tooltip="{{localize 'SVNSEA2E.OriginInfo'}}">{{localize "SVNSEA2E.Origin"}}</dt>
        <dd class="ro-field ship-origin">
          {{#if originItem}}<span class="dot" style="background:{{originDot}}"></span>{{originItem.name}}{{else}}<span class="unset">{{localize "SVNSEA2E.OriginUnset"}}</span>{{/if}}
        </dd>
        <dt data-tooltip="{{localize 'SVNSEA2E.HomePortInfo'}}">{{localize "SVNSEA2E.HomePort"}}</dt>
        <dd><select class="home-port-select" name="system.homeport">
          {{selectOptions config.nations selected=homeport localize=true}}
        </select></dd>
        <dt data-tooltip="{{localize 'SVNSEA2E.FlagInfo'}}">{{localize "SVNSEA2E.Flag"}}</dt>
        <dd><input type="text" name="system.flag" value="{{flag}}" placeholder="&mdash;" /></dd>
      </dl>

      <div class="res ship-res">
        <div class="cell" data-tooltip="{{localize 'SVNSEA2E.TreasuryInfo'}}"><div class="k">{{localize "SVNSEA2E.Treasury"}}</div><div class="v">{{wealth}}</div></div>
        <div class="cell" data-tooltip="{{localize 'SVNSEA2E.CrewInfo'}}"><div class="k">{{localize "SVNSEA2E.Crew"}}</div><div class="v">{{crewMax}}</div></div>
        <div class="cell" data-tooltip="{{localize 'SVNSEA2E.CargoInfo'}}"><div class="k">{{localize "SVNSEA2E.CargoHold"}}</div><div class="v">{{cargocap}}</div></div>
      </div>

      <div class="rail-morale status-row">
        <span class="k" data-tooltip="{{localize 'SVNSEA2E.MoraleInfo'}}">{{localize "SVNSEA2E.CrewMorale"}}</span>
        <div class="morale-pill-wrap">
          <select class="morale-select status-pill {{crewstatus}}" name="system.crewstatus">
            {{selectOptions config.crewStatuses selected=crewstatus localize=true}}
          </select>
        </div>
      </div>

      <div class="rail-sep"></div>

      {{!-- Hull: Hits (5 per Critical) + Critical-Hit seals (Crippled at 4). --}}
      <div class="rail-hull">
        <div class="lbl">
          <span>{{localize "SVNSEA2E.HullHits"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.HullInfo'}}"></i></span>
          <span class="hull-count">{{hits.value}} / {{hits.max}} &middot; {{hitsPerCritical}} {{localize "SVNSEA2E.PerCritical"}}</span>
        </div>
        <div class="track hull-track">
          {{#each hitPips}}<i class="{{#if filled}}on{{/if}}{{#if band5}} band5{{/if}}" data-type="hits" data-name="system.hits.value" data-value="{{n}}"></i>{{/each}}
        </div>

        <div class="crit-lbl">
          <span>{{localize "SVNSEA2E.CriticalHits"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.CriticalHitsInfo'}}"></i></span>
          <span>{{criticals.value}} &middot; {{localize "SVNSEA2E.CrippledAt"}} {{criticals.max}}</span>
        </div>
        <div class="spiral">
          {{#each critSeals}}
            <div class="seal fillable{{#if filled}} spent{{/if}}" data-type="criticals" data-name="system.criticals.value" data-value="{{level}}">
              <svg viewBox="0 0 52 52"><circle class="wax" cx="26" cy="26" r="22"/><path class="sig" d="M15 20 L37 32 M37 20 L15 32 M26 12 v28"/></svg>
            </div>
          {{/each}}
        </div>

        <div class="hull-status {{hullStatus.key}}">
          <span class="hs-label">{{hullStatus.label}}</span>
          <span class="hs-note">{{hullStatus.note}}</span>
        </div>

        {{#if shipBonuses.hull.length}}
          <ul class="ship-bonuses">
            {{#each shipBonuses.hull}}<li><i class="fas fa-star-of-life"></i> {{this}}</li>{{/each}}
          </ul>
        {{/if}}
      </div>
    </aside>

    {{!-- ===================== Ledger ===================== --}}
    <main class="sheet-main">
      <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="history"><h2>{{localize "SVNSEA2E.ShipHistory"}}</h2></a>
        <a class="item" data-tab="crew"><h2>{{localize "SVNSEA2E.Crew"}}</h2></a>
        <a class="item" data-tab="adventures"><h2>{{localize "SVNSEA2E.Adventures"}}</h2></a>
        <a class="item" data-tab="hold"><h2>{{localize "SVNSEA2E.Hold"}}</h2></a>
        <button type="button" class="theme-toggle" title="{{localize 'SVNSEA2E.ToggleTheme'}}"><i class="fas fa-circle-half-stroke"></i></button>
      </nav>

      <section class="sheet-body">

        {{!-- ===== Ship's History ===== --}}
        <div class="tab history" data-group="primary" data-tab="history">
          <div class="sec-title">
            <h3>{{localize "SVNSEA2E.Origin"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.OriginInfo'}}"></i></h3><span></span>
            <a class="add-btn browse-ship-pack" data-pack="theah.shiporigins" data-file="shiporigins" data-ptype="shiporigin" data-label="SVNSEA2E.ShipOrigin" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
          </div>
          <div class="prowess-list">
            {{#each origins as |item id|}}
              <div class="prowess-card origin item" data-item-id="{{item._id}}">
                <div class="pc-head">
                  <i class="fas fa-anchor pc-icon"></i>
                  <h4 class="pc-name">{{item.name}}</h4>
                  <span class="item-controls">
                    <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                {{#if item.system.description}}<div class="pc-desc">{{{item.system.description}}}</div>{{/if}}
                {{#if item.system.bonus}}<div class="pc-mech"><span class="pc-lbl">{{localize "SVNSEA2E.Bonus"}}</span>{{{item.system.bonus}}}</div>{{/if}}
              </div>
            {{else}}
              <p class="empty-note">{{localize "SVNSEA2E.NoOrigin"}}</p>
            {{/each}}
          </div>

          <div class="sec-title" style="margin-top:22px">
            <h3>{{localize "SVNSEA2E.Backgrounds"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.ShipBackgroundInfo'}}"></i></h3><span></span>
            <a class="add-btn browse-ship-pack" data-pack="theah.shipbackgrounds" data-file="shipbackgrounds" data-ptype="shipbackground" data-label="SVNSEA2E.ShipBackgrounds" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
          </div>
          <div class="prowess-list">
            {{#each backgrounds as |item id|}}
              <div class="prowess-card item" data-item-id="{{item._id}}">
                <div class="pc-head">
                  <i class="fas fa-scroll pc-icon"></i>
                  <h4 class="pc-name">{{item.name}}</h4>
                  <span class="item-controls">
                    <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                {{#if item.system.description}}<div class="pc-desc">{{{item.system.description}}}</div>{{/if}}
                {{#if item.system.bonus}}<div class="pc-mech"><span class="pc-lbl">{{localize "SVNSEA2E.Bonus"}}</span>{{{item.system.bonus}}}</div>{{/if}}
              </div>
            {{else}}
              <p class="empty-note">{{localize "SVNSEA2E.NoShipBackgrounds"}}</p>
            {{/each}}
          </div>

          <details class="roller-guide">
            <summary><i class="fas fa-circle-question"></i> {{localize "SVNSEA2E.HullGuideTitle"}}</summary>
            <ol class="rg-steps">
              <li>{{{localize "SVNSEA2E.HullGuide1"}}}</li>
              <li>{{{localize "SVNSEA2E.HullGuide2"}}}</li>
              <li>{{{localize "SVNSEA2E.HullGuide3"}}}</li>
            </ol>
            <div class="rg-live"><span class="rg-live-lbl">{{localize "SVNSEA2E.Example"}}</span> {{{localize "SVNSEA2E.HullGuideLive"}}}</div>
          </details>
        </div>

        {{!-- ===== Crew ===== --}}
        <div class="tab crew" data-group="primary" data-tab="crew">
          <div class="sec-title"><h3>{{localize "SVNSEA2E.CrewAndSquads"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.CrewInfo'}}"></i></h3><span></span></div>
          <p class="section-note">{{localize "SVNSEA2E.CrewExplain"}}</p>

          {{!-- Full complement (derived) + why --}}
          <div class="crew-strength">
            <span class="cs-k" data-tooltip="{{localize 'SVNSEA2E.CrewStrengthInfo'}}">{{localize "SVNSEA2E.CrewStrength"}}</span>
            <b class="cs-v">{{crewMax}}</b>
            <span class="cs-hint">{{localize "SVNSEA2E.SquadsMaxHint" n=squadMax}}</span>
          </div>
          {{#if shipBonuses.crew.length}}
            <ul class="ship-bonuses inline">
              {{#each shipBonuses.crew}}<li><i class="fas fa-star-of-life"></i> {{this}}</li>{{/each}}
            </ul>
          {{/if}}

          {{!-- Squad cards: inline division (name + strength stepper) OR a linked
               Brute Squad actor (live Strength, own sheet). Squads are NOT form
               inputs — names write via a change handler — so the ArrayField never
               round-trips through a submit (no stale/zeroing element re-clean).
               The Crew budget is enforced in code: adding a Squad grabs only the
               free Crew, and a Squad's Strength stepper stops at the remainder, so
               the total can never exceed the Crew (Core p.253). --}}
          <div class="squads-head">
            <span class="sq-title" data-tooltip="{{localize 'SVNSEA2E.SquadsInfo'}}">{{localize "SVNSEA2E.Squads"}}</span>
            <span class="sq-alloc {{#if squadOverAllocated}}over{{/if}}" data-tooltip="{{localize 'SVNSEA2E.AllocatedInfo'}}">{{localize "SVNSEA2E.Allocated"}} {{squadAllocated}} / {{crewMax}}</span>
            {{#if canAddSquad}}<button type="button" class="squad-add" data-tooltip="{{localize 'SVNSEA2E.AddSquadInfo'}}"><i class="fas fa-plus"></i> {{localize "SVNSEA2E.AddSquad"}}</button>{{/if}}
          </div>
          <p class="section-note squad-howto">{{{localize "SVNSEA2E.SquadHowTo"}}}</p>
          <div class="squad-list">
            {{#each squads as |sq id|}}
              <div class="squad {{#if sq.linked}}linked{{/if}} {{#if sq.missing}}missing{{/if}}" data-item-index="{{sq.index}}">
                <div class="sq-head">
                  {{#if sq.linked}}
                    {{#if sq.img}}<img class="sq-portrait" src="{{sq.img}}" alt="{{sq.name}}" />{{/if}}
                    <span class="sq-name linked-name" data-tooltip="{{localize 'SVNSEA2E.SquadLinkedHint'}}"><i class="fas fa-people-group"></i> {{sq.name}}{{#if sq.missing}} <em class="sq-missing">({{localize 'SVNSEA2E.SquadMissing'}})</em>{{/if}}</span>
                    {{#unless sq.missing}}<a class="squad-open" data-actor-id="{{sq.actorId}}" title="{{localize 'SVNSEA2E.OpenSquadSheet'}}"><i class="fas fa-arrow-up-right-from-square"></i></a>{{/unless}}
                  {{else}}
                    <input type="text" class="sq-name" data-index="{{sq.index}}" value="{{sq.name}}" placeholder="{{localize 'SVNSEA2E.SquadName'}}" />
                  {{/if}}
                  <a class="squad-remove" data-index="{{sq.index}}" title="{{localize 'SVNSEA2E.RemoveSquad'}}"><i class="fas fa-trash"></i></a>
                </div>
                <div class="sq-body">
                  {{#if sq.linked}}
                    <span class="sq-str-static" data-tooltip="{{localize 'SVNSEA2E.SquadLinkedHint'}}"><b class="sq-v">{{sq.strength}}<small>{{localize "SVNSEA2E.StrAbbr"}}</small></b></span>
                  {{else}}
                    <span class="stepper sq-step">
                      <button type="button" class="squad-str-step" data-index="{{sq.index}}" data-delta="-1" aria-label="-1">&minus;</button>
                      <b class="sq-v">{{sq.strength}}<small>{{localize "SVNSEA2E.StrAbbr"}}</small></b>
                      <button type="button" class="squad-str-step" data-index="{{sq.index}}" data-delta="1" aria-label="+1">+</button>
                    </span>
                  {{/if}}
                  <button type="button" class="squad-roll" data-index="{{sq.index}}" data-tooltip="{{localize 'SVNSEA2E.RollSquadInfo'}}" title="{{localize 'SVNSEA2E.RollSquad'}}"><i class="fas fa-dice-d20"></i> {{sq.strength}}d10</button>
                </div>
                <span class="pips" data-tooltip="{{localize 'SVNSEA2E.SquadPoolHint'}}">{{#each sq.pips}}<i></i>{{/each}}</span>
              </div>
            {{else}}
              <p class="empty-note">{{localize "SVNSEA2E.NoSquads"}}</p>
            {{/each}}
          </div>
          <p class="squad-drop-hint"><i class="fas fa-anchor"></i> {{localize "SVNSEA2E.DragBruteHint"}}</p>

          <div class="sec-title" style="margin-top:22px"><h3>{{localize "SVNSEA2E.Officers"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.OfficersInfo'}}"></i></h3><span></span></div>
          <p class="section-note">{{localize "SVNSEA2E.OfficersHint"}}</p>
          <ol class="items-list crew-roster">
            {{#each crew as |role|}}
              <li class="flexrow item-header {{role.cssClass}}" {{#each role.dataset as |v k|}}data-{{k}}="{{v}}" {{/each}}>
                <h3 class="role-name" {{#if role.tip}}data-tooltip="{{role.tip}}"{{/if}} {{#each role.dataset as |v k|}}data-{{k}}="{{v}}" {{/each}}>{{role.label}}{{#if role.tip}} <i class="fas fa-circle-info role-info"></i>{{/if}}</h3>
              </li>
              {{#each role.actors as |actor a|}}
                <li class="item flexrow draggable {{role.cssClass}}" data-actor-id="{{actor.id}}">
                  <div class="item-image"><img src="{{actor.img}}" title="{{actor.name}}" /></div>
                  <h4 class="crew-member-name">{{actor.name}}</h4>
                  <div class="item-controls">
                    <a class="item-control item-delete" title="{{localize 'SVNSEA2E.RemoveCrew'}}"><i class="fas fa-trash"></i></a>
                  </div>
                </li>
              {{/each}}
            {{/each}}
          </ol>

          <details class="roller-guide">
            <summary><i class="fas fa-circle-question"></i> {{localize "SVNSEA2E.CrewGuideTitle"}}</summary>
            <ol class="rg-steps">
              <li>{{{localize "SVNSEA2E.CrewGuide1"}}}</li>
              <li>{{{localize "SVNSEA2E.CrewGuide2"}}}</li>
              <li>{{{localize "SVNSEA2E.CrewGuide3"}}}</li>
              <li>{{{localize "SVNSEA2E.CrewGuide4"}}}</li>
            </ol>
            <div class="rg-live"><span class="rg-live-lbl">{{localize "SVNSEA2E.Example"}}</span> {{{localize "SVNSEA2E.CrewGuideLive"}}}</div>
          </details>
        </div>

        {{!-- ===== Adventures — Story-style earned trackers ===== --}}
        <div class="tab adventures" data-group="primary" data-tab="adventures">
          <div class="sec-title">
            <h3>{{localize "SVNSEA2E.Adventures"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.AdventuresInfo'}}"></i></h3><span></span>
            <a class="add-btn browse-ship-pack" data-pack="theah.shipadventures" data-file="shipadventures" data-ptype="shipadventure" data-label="SVNSEA2E.Adventures" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
          </div>
          <p class="section-note">{{localize "SVNSEA2E.AdventuresIntro"}}</p>
          <div class="prowess-list">
            {{#each adventures as |item id|}}
              <div class="prowess-card adventure item {{#if item.system.earned}}is-earned{{/if}}" data-item-id="{{item._id}}">
                <div class="pc-head">
                  <i class="fas fa-compass pc-icon"></i>
                  <h4 class="pc-name">{{item.name}}</h4>
                  {{#if item.system.earned}}<span class="earned-badge"><i class="fas fa-circle-check"></i> {{localize "SVNSEA2E.AdvEarned"}}</span>{{/if}}
                  <span class="item-controls">
                    <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
                    <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
                    <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
                  </span>
                </div>
                {{#if item.system.trigger}}<div class="pc-desc"><span class="pc-lbl">{{localize "SVNSEA2E.ShipAdvTrigger"}}</span>{{{item.system.trigger}}}</div>{{/if}}
                {{#if item.system.reward}}<div class="pc-mech reward-block"><span class="pc-lbl">{{localize "SVNSEA2E.Reward"}}</span>{{{item.system.reward}}}</div>{{/if}}
                <button type="button" class="adventure-earn {{#if item.system.earned}}on{{/if}}" data-item-id="{{item._id}}">
                  {{#if item.system.earned}}<i class="fas fa-circle-check"></i> {{localize "SVNSEA2E.AdvMarkUnearned"}}
                  {{else}}<i class="far fa-circle"></i> {{localize "SVNSEA2E.AdvMarkEarned"}}{{/if}}
                </button>
              </div>
            {{else}}
              <p class="empty-note">{{localize "SVNSEA2E.NoAdventures"}}</p>
            {{/each}}
          </div>
        </div>

        {{!-- ===== Hold — Cargo crates + Treasury ===== --}}
        <div class="tab hold" data-group="primary" data-tab="hold">
          <div class="sec-title">
            <h3>{{localize "SVNSEA2E.CargoHold"}} <i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.CargoInfo'}}"></i></h3><span></span>
            {{#if canAddCargo}}<a class="add-btn cargo-add" title="{{localize 'SVNSEA2E.AddCargo'}}"><i class="fas fa-plus"></i></a>{{/if}}
          </div>

          <div class="cargo-capline">
            <span class="section-note">{{localize "SVNSEA2E.CargoHoldIntro"}} <b>{{cargoUsed}} / {{cargocap}}</b> {{localize "SVNSEA2E.InHold"}}.</span>
            <span class="hc-k" data-tooltip="{{localize 'SVNSEA2E.CargoCapacityInfo'}}"><i class="fas fa-box-open"></i> {{localize "SVNSEA2E.CargoCapacity"}}</span>
            <b class="hc-v">{{cargocap}}</b>
          </div>
          {{#if shipBonuses.cargo.length}}
            <ul class="ship-bonuses inline">
              {{#each shipBonuses.cargo}}<li><i class="fas fa-star-of-life"></i> {{this}}</li>{{/each}}
            </ul>
          {{/if}}

          <div class="hold-grid">
            {{#each cargoSlots}}
              {{#if filled}}
                <div class="crate filled" data-index="{{index}}">
                  <i class="fas fa-box crate-icon"></i>
                  <div class="crate-body">
                    <input type="text" class="cargo-n" name="system.cargohold.{{index}}.name" value="{{name}}" placeholder="{{localize 'SVNSEA2E.CargoNamePlaceholder'}}" />
                    <input type="text" class="cargo-s" name="system.cargohold.{{index}}.note" value="{{note}}" placeholder="{{localize 'SVNSEA2E.CargoNotePlaceholder'}}" />
                  </div>
                  <a class="cargo-remove" data-index="{{index}}" title="{{localize 'SVNSEA2E.RemoveCargo'}}"><i class="fas fa-trash"></i></a>
                </div>
              {{else}}
                <div class="crate empty">
                  <i class="far fa-square crate-icon"></i>
                  <div class="crate-body"><div class="cargo-n">{{localize "SVNSEA2E.EmptyHold"}}</div><div class="cargo-s">{{localize "SVNSEA2E.RoomForCargo"}}</div></div>
                </div>
              {{/if}}
            {{/each}}
          </div>

          <div class="rail-sep hold-sep"></div>

          <div class="treasury-line">
            <span class="tl-coin"><i class="fas fa-coins"></i></span>
            <div class="tl-body">
              <div class="tl-head"><span class="tl-k" data-tooltip="{{localize 'SVNSEA2E.TreasuryInfo'}}">{{localize "SVNSEA2E.ShipsTreasury"}}</span>
                <span class="stepper">
                  <button type="button" class="treasury-step" data-delta="-1" aria-label="-1">&minus;</button>
                  <b class="hc-v">{{wealth}}</b>
                  <button type="button" class="treasury-step" data-delta="1" aria-label="+1">+</button>
                </span>
              </div>
              <div class="tl-note">{{localize "SVNSEA2E.TreasuryHint"}}</div>
            </div>
          </div>
        </div>

      </section>
    </main>

  </div>
</form>
