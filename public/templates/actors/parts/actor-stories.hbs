<div class="tab stories" data-group="primary" data-tab="stories">

  <div class="section-rule adv-head">
    <h3>{{localize "SVNSEA2E.Stories"}}</h3><span></span>
    <a class="item-control item-create add-btn" data-type="story" title="{{localize 'SVNSEA2E.AddStory'}}"><i class="fas fa-plus"></i></a>
  </div>
  <ul class="adv-list">
    {{#each stories as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost cost-plain"><i class="fas fa-scroll"></i></span>
        <h4 class="an item-name">{{item.name}}</h4>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{/each}}
  </ul>

  <div class="section-rule"><h3>{{localize "SVNSEA2E.Concept"}}</h3><span></span></div>
  {{editor concept target="system.concept" button=true owner=owner editable=editable}}

  {{#if isCorrupt}}
    <div class="section-rule"><h3>{{localize "SVNSEA2E.Redemption"}}</h3><span></span></div>
    <textarea name="system.redemption" class="redemption-text">{{redemption}}</textarea>
  {{/if}}
</div>
