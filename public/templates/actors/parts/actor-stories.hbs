<div class="tab stories" data-group="primary" data-tab="stories">

  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.Stories"}}</h3><span></span>
    <a class="add-btn new-advancement" title="{{localize 'SVNSEA2E.AdvNew'}}"><i class="fas fa-feather-pointed"></i></a>
    <a class="add-btn item-control item-create" data-type="story" title="{{localize 'SVNSEA2E.AddStory'}}"><i class="fas fa-plus"></i></a>
  </div>

  <ul class="story-list">
    {{#each stories as |item id|}}
      <li class="story-card item {{#if item.complete}}is-complete{{/if}} {{#if item.applied}}is-claimed{{/if}}" data-item-id="{{item._id}}">
        <div class="story-main">
          <span class="cost cost-plain"><i class="fas fa-scroll"></i></span>
          <h4 class="an item-name">{{item.name}}</h4>
          <span class="item-controls">
            <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
          </span>
        </div>

        {{#if item.isAdvancement}}
          <div class="story-adv">
            <div class="story-reward"><i class="fas fa-trophy"></i> {{item.rewardLabel}}</div>
            {{#if item.goal}}<div class="story-goal">&ldquo;{{item.goal}}&rdquo;</div>{{/if}}
            <div class="story-track" title="{{localize 'SVNSEA2E.AdvStepsHint'}}">
              {{#each item.pips}}
                <i class="story-step {{#if filled}}filled{{/if}}" data-story-id="{{item._id}}" data-step="{{n}}" title="{{localize 'SVNSEA2E.AdvStep'}} {{n}}"></i>
              {{/each}}
              <span class="story-count">{{item.stepsDone}}/{{item.stepsTotal}}</span>
            </div>
            {{#if item.applied}}
              <div class="story-claimed"><i class="fas fa-circle-check"></i> {{localize "SVNSEA2E.AdvClaimed"}}</div>
            {{else if item.claimable}}
              <button type="button" class="story-claim" data-story-id="{{item._id}}"><i class="fas fa-gift"></i> {{localize "SVNSEA2E.AdvClaim"}}</button>
            {{/if}}
          </div>
        {{/if}}
      </li>
    {{else}}
      <li class="story-card empty"><span class="ad">{{localize "SVNSEA2E.NoStories"}}</span></li>
    {{/each}}
  </ul>

  <div class="sec-title" style="margin-top:22px"><h3>{{localize "SVNSEA2E.Concept"}}</h3><span></span></div>
  {{editor concept target="system.concept" button=true owner=owner editable=editable}}

  {{#if isCorrupt}}
    <div class="sec-title" style="margin-top:22px"><h3>{{localize "SVNSEA2E.Redemption"}}</h3><span></span></div>
    <textarea name="system.redemption" class="redemption-text">{{redemption}}</textarea>
  {{/if}}
</div>
