<div class="tab traits" data-group="primary" data-tab="traits">

  {{!-- Traits: engraved medallions over a compass rose --}}
  <section class="theah-traits">
    <div class="section-rule"><h3>{{localize "SVNSEA2E.Traits"}}</h3><span></span></div>
    <div class="traits-row">
      {{#each traits as |trait key|}}
        <div class="trait-block">
          <div class="medallion"><span class="num">{{trait.value}}</span></div>
          <div class="pips">
            {{#for 1 trait.max 1}}
              {{#iff trait.value '>=' @index}}
                <i data-name="system.traits.{{trait.name}}.value" data-value="{{@index}}" data-type="trait" data-key="{{trait.name}}" class="fillable rating on"></i>
              {{else}}
                <i data-name="system.traits.{{trait.name}}.value" data-value="{{@index}}" data-type="trait" data-key="{{trait.name}}" class="fillable rating"></i>
              {{/iff}}
            {{/for}}
          </div>
          <div class="tname">{{trait.label}}</div>
        </div>
      {{/each}}
    </div>
  </section>

  {{#if hasSkills}}
    {{!-- Skills ledger: name (rollable) · pips · value --}}
    <div class="section-rule"><h3>{{localize "SVNSEA2E.Skills"}}</h3><span></span></div>
    <div class="theah-skills">
      {{#each skills as |skill key|}}
        <div class="skill-row">
          <span class="skill-name rollable" data-roll="{{skill.value}}" data-label="{{skill.name}}" title="{{localize 'SVNSEA2E.Roll'}}">{{skill.label}}</span>
          <div class="pips">
            {{#for 1 skill.max 1}}
              {{#iff skill.value '>=' @index}}
                <i data-name="system.skills.{{skill.name}}.value" data-value="{{@index}}" data-type="skill" data-key="{{skill.name}}" class="fillable rating on"></i>
              {{else}}
                <i data-name="system.skills.{{skill.name}}.value" data-value="{{@index}}" data-type="skill" data-key="{{skill.name}}" class="fillable rating"></i>
              {{/iff}}
            {{/for}}
          </div>
          <span class="val">{{skill.value}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if hasLanguages}}
    <div class="section-rule"><h3>{{localize "SVNSEA2E.Languages"}}</h3><span></span></div>
    <div class="language flexrow flex-group flex-left">
      <ul class="tag-list">
        {{#each selectedlangs as |k v|}}
          <li class="tag {{v}}">{{k}}</li>
        {{/each}}
      </ul>
      <a class="language-selector" data-options="languages"><i class="fas fa-edit"></i></a>
    </div>
  {{/if}}
</div>
