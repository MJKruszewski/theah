{{#if isPlayerCharacter}}
  <div class="res">
    <div class="cell">
      <div class="k">{{localize "SVNSEA2E.HeroPoints"}}</div>
      <div class="v"><input type="text" name="system.heropts" value="{{heropts}}" /></div>
    </div>
    <div class="cell">
      <div class="k">{{localize "SVNSEA2E.WealthPts"}}</div>
      <div class="v"><input type="text" name="system.wealth" value="{{wealth}}" data-dtype="String" /></div>
    </div>
    <div class="cell">
      <div class="k">{{localize "SVNSEA2E.Reputation"}}</div>
      <div class="v"><input type="text" name="system.reputation" value="{{reputation}}" placeholder="—" /></div>
    </div>
  </div>

  <div class="init-row">
    <span class="k">{{localize "SVNSEA2E.Initiative"}}</span>
    <div class="init-ctl">
      <button type="button" class="minus-1-initiative" aria-label="-1">&minus;</button>
      <input type="text" name="system.initiative" value="{{initiative}}" disabled />
      <button type="button" class="add-1-initiative" aria-label="+1">+</button>
    </div>
  </div>

  <div class="rail-corruption {{#if isCorrupt}}is-corrupt{{/if}}">
    <div class="lbl"><span>{{localize "SVNSEA2E.Corruption"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.CorruptionInfo'}}"></i></span><span>{{corruptionpts}} / 10</span></div>
    <div class="corruption-pips">
      {{#for 1 10 1}}
        {{#iff corruptionpts '>=' @index}}
          <i data-name="system.corruptionpts" data-value="{{@index}}" data-type="corrupt" data-key="corruptionpts" class="fillable rating corrupt on"></i>
        {{else}}
          <i data-name="system.corruptionpts" data-value="{{@index}}" data-type="corrupt" data-key="corruptionpts" class="fillable rating corrupt"></i>
        {{/iff}}
      {{/for}}
    </div>
    {{#if isGM}}
      <button type="button" class="evil-act-roll" data-tooltip="{{localize 'SVNSEA2E.EvilActHint'}}">
        <i class="fas fa-skull"></i> {{localize "SVNSEA2E.EvilAct"}}
      </button>
    {{/if}}
  </div>

  <div class="rail-sep"></div>
{{/if}}

<div class="wounds">
  <div class="lbl"><span>{{localize "SVNSEA2E.Wounds"}}</span><span>{{wounds.value}} / {{wounds.max}}</span></div>
  <div class="track">
    {{#for 1 wounds.max 1}}
      {{#iff wounds.value '>=' @index}}
        <i data-name="system.wounds.value" data-value="{{@index}}" data-type="wounds" class="fillable wound on" title="{{@index}}"></i>
      {{else}}
        <i data-name="system.wounds.value" data-value="{{@index}}" data-type="wounds" class="fillable wound" title="{{@index}}"></i>
      {{/iff}}
    {{/for}}
  </div>

  {{#if isNotBrute}}
    <div class="lbl" style="margin-top:12px"><span>{{localize "SVNSEA2E.DramaticWounds"}}</span><span>{{dwounds.value}} · {{localize "SVNSEA2E.DeathSpiral"}}</span></div>
    <div class="spiral">
      {{#each dwoundSeals}}
        <div class="seal {{#if filled}}spent {{/if}}fillable wound dramatic" data-name="system.dwounds.value" data-value="{{level}}" data-type="dwounds" data-tooltip="{{tip}}">
          <svg viewBox="0 0 52 52"><circle class="wax" cx="26" cy="26" r="22"/><path class="sig" d="M18 30 L26 16 L34 30 M21 26 h10"/></svg>
        </div>
      {{/each}}
    </div>
  {{/if}}
</div>
