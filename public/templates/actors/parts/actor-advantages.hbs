<div class="tab features" data-group="primary" data-tab="advantages">

  {{!-- Advantages: cost medallion + name (click to expand) --}}
  <div class="sec-title">
    <h3>{{localize 'SVNSEA2E.Advantages'}}</h3><span></span>
    <a class="add-btn open-compendium" data-pack="theah.advantages" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
  </div>
  <ul class="adv-list">
    {{#each advantages as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost">{{#if item.system.cost.normal}}{{item.system.cost.normal}}{{else}}·{{/if}}</span>
        <h4 class="an item-name">{{item.name}}{{#if item.system.knack}} <i class="fas fa-award badge" title="{{localize 'SVNSEA2E.Knack'}}"></i>{{/if}}{{#if item.system.innate}} <i class="fas fa-seedling badge" title="{{localize 'SVNSEA2E.Innate'}}"></i>{{/if}}</h4>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{/each}}
  </ul>

  {{!-- Backgrounds as tags --}}
  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.Backgrounds"}}</h3><span></span>
    <a class="add-btn open-compendium" data-pack="theah.backgrounds" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
  </div>
  <ul class="tag-list bg-tags">
    {{#each backgrounds as |item id|}}
      <li class="tag item" data-item-id="{{item._id}}">
        <span class="item-name">{{item.name}}</span>
        <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
        <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
      </li>
    {{/each}}
  </ul>

  {{!-- Dueling styles --}}
  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.DuelingStyles"}}</h3><span></span>
    <a class="item-control item-create add-btn" title="{{localize 'SVNSEA2E.AddDuelStyle'}}" data-type="duelstyle"><i class="fas fa-plus"></i></a>
  </div>
  <ul class="adv-list">
    {{#each duelstyles as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost cost-plain"><i class="fas fa-fencing"></i></span>
        <h4 class="an item-name">{{item.name}}</h4>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{/each}}
  </ul>

  {{!-- Secret societies --}}
  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.SecretSociety"}}</h3><span></span>
    <a class="item-control item-create add-btn" title="{{localize 'SVNSEA2E.AddSecretSociety'}}" data-type="secretsociety"><i class="fas fa-plus"></i></a>
  </div>
  <ul class="adv-list">
    {{#each secretsocieties as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost cost-plain"><i class="fas fa-user-secret"></i></span>
        <h4 class="an item-name">{{item.name}}</h4>
        <span class="favor-tag">{{localize 'SVNSEA2E.Favor'}} {{item.system.favor}}</span>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{/each}}
  </ul>
</div>
