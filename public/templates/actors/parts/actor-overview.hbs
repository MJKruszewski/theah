<div class="tab overview" data-group="primary" data-tab="traits">

  {{!-- Traits: engraved medallions over a compass rose --}}
  <div class="sec-title"><h3>{{localize "SVNSEA2E.Traits"}}</h3><span></span></div>
  <div class="traits">
    <div class="compass-bg" aria-hidden="true">
      <svg viewBox="0 0 100 100"><g fill="none" stroke="currentColor" stroke-width="1">
        <circle cx="50" cy="50" r="46"/><circle cx="50" cy="50" r="34"/>
        <path d="M50 4 L54 50 L50 96 L46 50 Z M4 50 L50 46 L96 50 L50 54 Z"/>
        <path d="M22 22 L50 47 L78 78 M78 22 L50 47 L22 78" stroke-width=".6"/>
      </g></svg>
    </div>
    {{#each traits as |trait key|}}
      <div class="trait">
        <div class="medallion"><span class="num">{{trait.value}}</span></div>
        <div class="pips">
          {{#for 1 trait.max 1}}
            {{#iff trait.value '>=' @index}}
              <i data-name="system.traits.{{trait.name}}.value" data-value="{{@index}}" data-type="trait" data-key="{{trait.name}}" class="fillable rating on"></i>
            {{else}}
              <i data-name="system.traits.{{trait.name}}.value" data-value="{{@index}}" data-type="trait" data-key="{{trait.name}}" class="fillable rating"></i>
            {{/iff}}
          {{/for}}
        </div>
        <div class="tname">{{trait.label}}<i class="fas fa-circle-info info-dot" data-tooltip="{{trait.desc}}"></i></div>
      </div>
    {{/each}}
  </div>

  {{#if hasSkills}}
    <div class="sec-title"><h3>{{localize "SVNSEA2E.Skills"}}</h3><span></span></div>
    <div class="skills">
      {{#each skills as |skill key|}}
        <div class="skill">
          <span class="sname rollable" data-roll="{{skill.value}}" data-label="{{skill.name}}" title="{{localize 'SVNSEA2E.Roll'}}">{{skill.label}}</span>
          <i class="fas fa-circle-info info-dot" data-tooltip="{{skill.desc}}"></i>
          <div class="pips">
            {{#for 1 skill.max 1}}
              {{#iff skill.value '>=' @index}}
                <i data-name="system.skills.{{skill.name}}.value" data-value="{{@index}}" data-type="skill" data-key="{{skill.name}}" class="fillable rating on"></i>
              {{else}}
                <i data-name="system.skills.{{skill.name}}.value" data-value="{{@index}}" data-type="skill" data-key="{{skill.name}}" class="fillable rating"></i>
              {{/iff}}
            {{/for}}
          </div>
          <span class="val">{{skill.value}}</span>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- Lower two-up: Arcana + Backgrounds | Advantages --}}
  <div class="lower">
    <div class="lower-col">
      <div class="sec-title">
        <h3>{{localize "SVNSEA2E.Arcana"}}</h3><span></span>
        <a class="add-btn open-compendium" data-pack="theah.arcana" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
      </div>
      <div class="arcana">
        {{#each virtues as |item id|}}
          <div class="card virtue item" data-item-id="{{item._id}}">
            <div class="card-controls">
              <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
              <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
              <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
            </div>
            <div class="kind">{{localize "SVNSEA2E.Virtue"}}</div>
            <div class="cname item-name">{{item.name}}</div>
            <div class="ctext">{{{item.system.description}}}</div>
            <div class="corner-mark">&#10022;</div>
          </div>
        {{/each}}
        {{#each hubriss as |item id|}}
          <div class="card hubris item" data-item-id="{{item._id}}">
            <div class="card-controls">
              <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
              <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
              <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
            </div>
            <div class="kind">{{localize "SVNSEA2E.Hubris"}}</div>
            <div class="cname item-name">{{item.name}}</div>
            <div class="ctext">{{{item.system.description}}}</div>
            <div class="corner-mark">&#10038;</div>
          </div>
        {{/each}}
        {{#unless virtues.length}}{{#unless hubriss.length}}
          <div class="arcana-empty">{{localize "SVNSEA2E.NoArcana"}}</div>
        {{/unless}}{{/unless}}
      </div>

      <div class="sec-title" style="margin-top:22px">
        <h3>{{localize "SVNSEA2E.Backgrounds"}}</h3><span></span>
        <a class="add-btn open-compendium" data-pack="theah.backgrounds" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
      </div>
      <ul class="bg-tags">
        {{#each backgrounds as |item id|}}
          <li class="tag item" data-item-id="{{item._id}}">
            <span class="item-name item-edit">{{item.name}}</span>
            <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
            <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-times"></i></a>
          </li>
        {{else}}
          <li class="bg-empty">{{localize "SVNSEA2E.NoBackgrounds"}}</li>
        {{/each}}
      </ul>
    </div>

    <div class="lower-col">
      <div class="sec-title">
        <h3>{{localize "SVNSEA2E.Advantages"}}</h3><span></span>
        <a class="add-btn open-compendium" data-pack="theah.advantages" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
      </div>
      <ul class="perk-list">
        {{#each advantages as |item id|}}
          <li class="perk-row item" data-item-id="{{item._id}}">
            <span class="cost">{{#if item.system.cost.normal}}{{item.system.cost.normal}}{{else}}&middot;{{/if}}</span>
            <h4 class="an item-name">{{item.name}}{{#if item.system.knack}} <i class="fas fa-award badge" title="{{localize 'SVNSEA2E.Knack'}}"></i>{{/if}}{{#if item.system.innate}} <i class="fas fa-seedling badge" title="{{localize 'SVNSEA2E.Innate'}}"></i>{{/if}}</h4>
            <span class="item-controls">
              <a class="item-control item-to-chat" title="{{localize 'SVNSEA2E.PostToChat'}}"><i class="fas fa-comment"></i></a>
              <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
              <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
            </span>
          </li>
        {{else}}
          <li class="perk-row"><span class="empty-note" style="color:var(--ink-soft);font-style:italic">{{localize "SVNSEA2E.NoAdvantages"}}</span></li>
        {{/each}}
      </ul>
    </div>
  </div>

  {{!-- Raises roller (signature mechanic) --}}
  <div class="roller" data-dw-bonus="{{dwBonus}}">
    <div class="top">
      <div class="formula">
        <i class="fas fa-circle-info roller-info" data-tooltip="{{localize 'SVNSEA2E.RaisesInfo'}}"></i>
        <select class="rp-trait" aria-label="{{localize 'SVNSEA2E.Trait'}}">
          {{#each traits as |t|}}<option value="{{t.value}}" data-key="{{t.name}}">{{t.label}} &middot; {{t.value}}</option>{{/each}}
        </select>
        <span>+</span>
        <select class="rp-skill" aria-label="{{localize 'SVNSEA2E.Skill'}}">
          {{#each skills as |s|}}<option value="{{s.value}}" data-key="{{s.name}}">{{s.label}} &middot; {{s.value}}</option>{{/each}}
        </select>
        <span>=</span> <b class="pool-count">0</b> <span>d10</span>
        <span class="sets-hint" data-tooltip="{{localize 'SVNSEA2E.RaisesInfo'}}">&middot; {{localize "SVNSEA2E.SetsOfTen"}}</span>
      </div>
      <div class="hp-ctl" data-tooltip="{{localize 'SVNSEA2E.HeroPointDiceInfo'}}">
        <span class="hp-avail"><i class="fas fa-star"></i> <b>{{heropts}}</b> {{localize "SVNSEA2E.HeroPoints"}}</span>
        <span class="hp-spend-lbl">{{localize "SVNSEA2E.Spend"}}</span>
        <button type="button" class="hpd-step" data-hpd-delta="-1" aria-label="-1">&minus;</button>
        <span class="hpd-val" data-max="{{heropts}}">0</span>
        <button type="button" class="hpd-step" data-hpd-delta="1" aria-label="+1">+</button>
      </div>
      <button type="button" class="roll-btn roll-pool">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="3"/><circle cx="9" cy="9" r="1.3" fill="currentColor"/><circle cx="15" cy="15" r="1.3" fill="currentColor"/><circle cx="15" cy="9" r="1.3" fill="currentColor"/><circle cx="9" cy="15" r="1.3" fill="currentColor"/></svg>
        {{localize "SVNSEA2E.RollThePool"}}
      </button>
    </div>
    <div class="mods">
      <div class="bonus-ctl" data-tooltip="{{localize 'SVNSEA2E.BonusDiceInfo'}}">
        <span class="mod-lbl">{{localize "SVNSEA2E.BonusDice"}}</span>
        <button type="button" class="bonus-step" data-bonus-delta="-1" aria-label="-1">&minus;</button>
        <span class="bonus-val">0</span>
        <button type="button" class="bonus-step" data-bonus-delta="1" aria-label="+1">+</button>
      </div>
      {{#if dwBonus}}
        <span class="mod-chip dw" data-tooltip="{{localize 'SVNSEA2E.DwBonusInfo'}}"><i class="fas fa-heart-crack"></i> +1 {{localize "SVNSEA2E.DramaticWound"}}</span>
      {{/if}}
      <label class="mod-check" data-tooltip="{{localize 'SVNSEA2E.ExplodeInfo'}}">
        <input type="checkbox" class="rp-explode" {{#if autoExplode}}checked{{/if}} /> {{localize "SVNSEA2E.ExplodingTens"}}{{#if autoExplode}} <i class="fas fa-lock" title="{{localize 'SVNSEA2E.AutoAtThreeDw'}}"></i>{{/if}}
      </label>
      {{#if hasJoie}}
        <label class="mod-check" data-tooltip="{{localize 'SVNSEA2E.JoieInfo'}}">
          <input type="checkbox" class="rp-joie" /> {{localize "SVNSEA2E.JoieDeVivre"}} <span class="mod-cost">(1 <i class="fas fa-star"></i>)</span>
        </label>
      {{else}}
        <label class="mod-check disabled" data-tooltip="{{localize 'SVNSEA2E.JoieInfo'}}">
          <input type="checkbox" class="rp-joie" disabled /> {{localize "SVNSEA2E.JoieDeVivre"}} <span class="mod-req" data-tooltip="{{localize 'SVNSEA2E.JoieRequires'}}"><i class="fas fa-lock"></i></span>
        </label>
      {{/if}}
    </div>
    <div class="result">
      <div class="dice"></div>
      <div class="raises">
        <span class="big">0</span>
        <div><div class="lab" data-tooltip="{{localize 'SVNSEA2E.RaisesInfo'}}">{{localize "SVNSEA2E.RaisesLabel"}} <i class="fas fa-circle-info"></i></div><div class="combos"></div></div>
      </div>
      <div class="reroll-hint"></div>
    </div>

    <details class="roller-guide">
      <summary><i class="fas fa-circle-question"></i> {{localize "SVNSEA2E.RollerGuideTitle"}}</summary>
      <ol class="rg-steps">
        <li>{{{localize "SVNSEA2E.GuideStep1"}}}</li>
        <li>{{{localize "SVNSEA2E.GuideStep2"}}}</li>
        <li>{{{localize "SVNSEA2E.GuideStep3"}}}</li>
        <li>{{{localize "SVNSEA2E.GuideStep4"}}}</li>
      </ol>
      <div class="rg-live"><span class="rg-live-lbl">{{localize "SVNSEA2E.GuideLiveTitle"}}</span> {{localize "SVNSEA2E.RiskExample"}}</div>
    </details>
  </div>

</div>
