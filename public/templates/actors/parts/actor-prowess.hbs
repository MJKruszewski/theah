<div class="tab prowess" data-group="primary" data-tab="prowess">

  {{!-- Dueling styles — compendium-locked; browse & drag from the pack. --}}
  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.DuelingStyles"}}</h3><span></span>
    <a class="add-btn open-compendium" data-pack="theah.duelstyles" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
  </div>
  <div class="prowess-list">
    {{#each duelstyles as |item id|}}
      <div class="prowess-card item" data-item-id="{{item._id}}">
        <div class="pc-head">
          <i class="fas fa-khanda pc-icon"></i>
          <h4 class="pc-name">{{item.name}}</h4>
          <span class="item-controls">
            <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{#if item.system.description}}<div class="pc-desc">{{{item.system.description}}}</div>{{/if}}
        {{#if item.system.bonus}}<div class="pc-mech">{{{item.system.bonus}}}</div>{{/if}}
      </div>
    {{else}}
      <p class="empty-note">{{localize "SVNSEA2E.NoDuelingStyles"}}</p>
    {{/each}}
  </div>

  {{!-- Secret societies — compendium-locked; browse & drag from the pack. --}}
  <div class="sec-title" style="margin-top:22px">
    <h3>{{localize "SVNSEA2E.SecretSociety"}}</h3><span></span>
    <a class="add-btn open-compendium" data-pack="theah.secretsocieties" title="{{localize 'SVNSEA2E.BrowseCompendium'}}"><i class="fas fa-book-open"></i></a>
  </div>
  <div class="prowess-list">
    {{#each secretsocieties as |item id|}}
      <div class="prowess-card society item" data-item-id="{{item._id}}">
        <div class="pc-head">
          <i class="fas fa-user-secret pc-icon"></i>
          <h4 class="pc-name">{{item.name}}</h4>
          <span class="favor-tag" title="{{localize 'SVNSEA2E.Favor'}}"><i class="fas fa-hand-holding-heart"></i> {{localize 'SVNSEA2E.Favor'}} {{item.system.favor}}</span>
          <span class="item-controls">
            <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
            <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{#if item.system.description}}<div class="pc-desc">{{{item.system.description}}}</div>{{/if}}
        {{#if item.system.concern}}<div class="pc-concern"><span class="pc-lbl">{{localize "SVNSEA2E.Concern"}}</span>{{{item.system.concern}}}</div>{{/if}}
        {{#if item.system.earnfavor}}<div class="pc-favor-block"><span class="pc-lbl">{{localize "SVNSEA2E.EarnFavor"}}</span>{{{item.system.earnfavor}}}</div>{{/if}}
        {{#if item.system.callupon}}<div class="pc-favor-block"><span class="pc-lbl">{{localize "SVNSEA2E.UseFavor"}}</span>{{{item.system.callupon}}}</div>{{/if}}
      </div>
    {{else}}
      <p class="empty-note">{{localize "SVNSEA2E.NoSecretSocieties"}}</p>
    {{/each}}
  </div>

</div>
