<div class="tab prowess" data-group="primary" data-tab="prowess">

  {{!-- Dueling styles --}}
  <div class="sec-title">
    <h3>{{localize "SVNSEA2E.DuelingStyles"}}</h3><span></span>
    <a class="add-btn item-control item-create" title="{{localize 'SVNSEA2E.AddDuelStyle'}}" data-type="duelstyle"><i class="fas fa-plus"></i></a>
  </div>
  <ul class="adv-list">
    {{#each duelstyles as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost cost-plain"><i class="fas fa-khanda"></i></span>
        <h4 class="an item-name">{{item.name}}</h4>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{else}}
      <li class="adv-row"><span class="ad" style="color:var(--ink-soft);font-style:italic">{{localize "SVNSEA2E.NoDuelingStyles"}}</span></li>
    {{/each}}
  </ul>

  {{!-- Secret societies --}}
  <div class="sec-title" style="margin-top:22px">
    <h3>{{localize "SVNSEA2E.SecretSociety"}}</h3><span></span>
    <a class="add-btn item-control item-create" title="{{localize 'SVNSEA2E.AddSecretSociety'}}" data-type="secretsociety"><i class="fas fa-plus"></i></a>
  </div>
  <ul class="adv-list">
    {{#each secretsocieties as |item id|}}
      <li class="adv-row item" data-item-id="{{item._id}}">
        <span class="cost cost-plain"><i class="fas fa-user-secret"></i></span>
        <h4 class="an item-name">{{item.name}}</h4>
        <span class="favor-tag">{{localize 'SVNSEA2E.Favor'}} {{item.system.favor}}</span>
        <span class="item-controls">
          <a class="item-control item-edit" title="{{item.editlabel}}"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="{{item.deletelabel}}"><i class="fas fa-trash"></i></a>
        </span>
      </li>
    {{else}}
      <li class="adv-row"><span class="ad" style="color:var(--ink-soft);font-style:italic">{{localize "SVNSEA2E.NoSecretSocieties"}}</span></li>
    {{/each}}
  </ul>

</div>
