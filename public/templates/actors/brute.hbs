<form class="{{cssClass}} flexcol" autocomplete="off">
  <div class="theah-layout brute-layout">

    {{!-- ===================== Identity rail ===================== --}}
    <aside class="identity-rail">
      <span class="edge"></span>

      <div class="portrait brute-portrait">
        <img class="profile-img" src="{{img}}" data-edit="img" title="{{name}}" alt="{{name}}" />
        <svg class="corner tl" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner tr" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner bl" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
        <svg class="corner br" viewBox="0 0 26 26"><path d="M2 24 V6 Q2 2 6 2 H24"/></svg>
      </div>

      <div class="nameplate">
        <input class="name" type="text" name="name" value="{{name}}" placeholder="{{localize 'SVNSEA2E.ActorName'}}" />
      </div>

      <div class="filet" aria-hidden="true">
        <svg viewBox="0 0 34 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"><path d="M2 13 C 11 11, 24 8, 31 3 M31 3 l-3 .3 M31 3 l-.3 3 M6 13 l3 0 M4 11 l0 3"/><path d="M32 13 C 23 11, 10 8, 3 3 M3 3 l3 .3 M3 3 l.3 3"/></svg>
      </div>

      <div class="type-row">
        <span data-tooltip="{{localize 'SVNSEA2E.BruteTypeInfo'}}">{{localize "SVNSEA2E.SquadType"}}</span>
        <select class="squad-type-select type-pill {{squadTypeClass}}" name="system.squadtype">
          {{selectOptions bruteTypeChoices selected=squadtype localize=true}}
        </select>
      </div>

      {{!-- ===== The Muster: Strength as a rank of figures (Core p.191) ===== --}}
      <section class="muster">
        <div class="lbl">
          <span>{{localize "SVNSEA2E.TraitStrength"}}</span>
          <span class="info" data-tooltip="{{localize 'SVNSEA2E.BruteStrengthInfo'}}">{{localize "SVNSEA2E.BruteOnlyStat"}} <i class="fas fa-circle-info"></i></span>
        </div>
        <div class="count">
          <span class="now">{{strengthCur}}</span><span class="of"> / {{strengthMax}}</span>
        </div>
        <div class="rank">
          {{#each figures}}
            <div class="fig {{#unless standing}}down{{/unless}}" data-level="{{level}}">
              <svg viewBox="0 0 24 30"><path d="M12 2.4c-2.5 0-4 1.7-4 4 0 1.5.7 2.8 1.7 3.5-2.6.9-4.7 2.7-5.4 5.5-.3 1.2-.4 2.6-.4 4.2v7.6c0 .6.4 1 1 1h14.2c.6 0 1-.4 1-1v-7.6c0-1.6-.1-3-.4-4.2-.7-2.8-2.8-4.6-5.4-5.5 1-.7 1.7-2 1.7-3.5 0-2.3-1.5-4-4-4z"/></svg>
            </div>
          {{/each}}
        </div>
        <div class="muster-ctl">
          <button type="button" class="str-step raise" data-delta="-1" data-tooltip="{{localize 'SVNSEA2E.BruteRaiseInfo'}}">&minus;1 {{localize "SVNSEA2E.RaisesLabel"}}</button>
          <button type="button" class="str-step recruit" data-delta="1" data-tooltip="{{localize 'SVNSEA2E.BruteReinforceInfo'}}">&plus;1</button>
          <button type="button" class="muster-btn" data-tooltip="{{localize 'SVNSEA2E.BruteMusterInfo'}}">{{localize "SVNSEA2E.BruteMuster"}}</button>
        </div>
        <div class="brute-size">
          <label for="brute-size-input">{{localize "SVNSEA2E.BruteSize"}}</label>
          <input id="brute-size-input" type="number" min="0" name="system.traits.strength.max" value="{{strengthMax}}" />
        </div>
      </section>

      {{!-- ===== Threat: deals Wounds = current Strength (Core p.192) ===== --}}
      <section class="threat {{#if defeated}}defeated{{/if}}">
        {{#if defeated}}
          <div class="v">{{localize "SVNSEA2E.BruteDefeatedShort"}}</div>
          <div class="n">{{localize "SVNSEA2E.BruteDefeatedThreat"}}</div>
        {{else}}
          <div class="k">{{localize "SVNSEA2E.BruteDealsLabel"}} <span class="info" data-tooltip="{{localize 'SVNSEA2E.BruteDealsInfo'}}"><i class="fas fa-circle-info"></i></span></div>
          <div class="v"><b>{{dealsWounds}}</b> {{localize "SVNSEA2E.Wounds"}}</div>
          <div class="n">{{localize "SVNSEA2E.BruteDealsNote"}}</div>
        {{/if}}
      </section>
    </aside>

    {{!-- ===================== Ledger ===================== --}}
    <main class="sheet-main brute-ledger">

      <div class="sec-title"><h3>{{localize "SVNSEA2E.BruteSpecialAbility"}}</h3><span></span></div>

      {{#if hasAbility}}
        <div class="ability-card">
          <svg class="rose" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6z"/></svg>
          <div class="ah">
            <span class="ai"><i class="fas fa-shield-halved"></i></span>
            <div>
              <div class="al">{{squadTypeLabel}} &middot; {{localize "SVNSEA2E.BruteSpecialSquad"}}</div>
              {{#if isCustomSquad}}
                <input class="custom-ability-name" type="text" name="system.ability.name" value="{{ability.name}}" placeholder="{{localize 'SVNSEA2E.BruteAbilityNamePlaceholder'}}" />
              {{else}}
                <h4 class="an">{{abilityName}}</h4>
              {{/if}}
            </div>
            <span class="cost">{{abilityCost}}</span>
          </div>
          {{#if isCustomSquad}}
            <textarea class="custom-ability-desc" name="system.ability.description" rows="4" placeholder="{{localize 'SVNSEA2E.BruteAbilityDescPlaceholder'}}">{{ability.description}}</textarea>
          {{else}}
            <div class="abil-desc">{{{abilityDesc}}}</div>
          {{/if}}
          <button type="button" class="activate-ability"><i class="fas fa-bolt-lightning"></i> {{localize "SVNSEA2E.BruteActivate"}}</button>
        </div>
      {{else}}
        <div class="ability-empty">{{localize "SVNSEA2E.BruteNoAbility"}}</div>
      {{/if}}

      <div class="sec-title"><h3>{{localize "SVNSEA2E.BruteEngaging"}}</h3><span></span></div>
      <details class="roller-guide brute-guide" open>
        <summary>{{localize "SVNSEA2E.BruteGuideTitle"}} <span class="ref">{{localize "SVNSEA2E.BruteGuideRef"}}</span></summary>
        <ol class="rg-steps">
          <li><b>{{localize "SVNSEA2E.BruteStep1"}}</b> — {{localize "SVNSEA2E.BruteStep1Text"}}</li>
          <li><b>{{localize "SVNSEA2E.BruteStep2"}}</b> — {{{localize "SVNSEA2E.BruteStep2Text"}}}</li>
          <li><b>{{localize "SVNSEA2E.BruteStep3"}}</b> — {{{localize "SVNSEA2E.BruteStep3Text"}}}</li>
          <li><b>{{localize "SVNSEA2E.BruteStep4"}}</b> — {{{localize "SVNSEA2E.BruteStep4Text"}}}</li>
          <li><b>{{localize "SVNSEA2E.BruteStep5"}}</b> — {{localize "SVNSEA2E.BruteStep5Text"}}</li>
        </ol>
        <div class="rg-live"><span class="rg-live-lbl">{{localize "SVNSEA2E.Example"}}</span> {{{localize "SVNSEA2E.BruteGuideLive"}}}</div>
      </details>

      <div class="sec-title"><h3>{{localize "SVNSEA2E.BruteReorganize"}}</h3><span></span></div>
      <p class="reorg">{{{localize "SVNSEA2E.BruteReorganizeText"}}}</p>

    </main>
  </div>
</form>
