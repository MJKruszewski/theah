<form class="risk-builder-form" autocomplete="off">
  <p class="rb-intro">{{localize "SVNSEA2E.RiskBuilderIntro"}}</p>

  {{#if hasSaved}}
    <div class="rb-library">
      <div class="rb-lib-head"><i class="fas fa-book-bookmark"></i> {{localize "SVNSEA2E.RiskLibrary"}}</div>
      <ul class="rb-lib-list">
        {{#each savedRisks}}
          <li class="rb-lib-item">
            <span class="rb-lib-name">{{name}}</span>
            <span class="rb-lib-ctl">
              <a class="rb-post-saved" data-id="{{id}}" data-tooltip="{{localize 'SVNSEA2E.RiskPostThis'}}"><i class="fas fa-comment"></i></a>
              <a class="rb-load" data-id="{{id}}" data-tooltip="{{localize 'SVNSEA2E.RiskLoad'}}"><i class="fas fa-pen-to-square"></i></a>
              <a class="rb-delete" data-id="{{id}}" data-tooltip="{{localize 'SVNSEA2E.Remove'}}"><i class="fas fa-trash"></i></a>
            </span>
          </li>
        {{/each}}
      </ul>
    </div>
  {{/if}}

  <div class="rb-field">
    <label>{{localize "SVNSEA2E.RiskName"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.RiskNameHint'}}"></i></label>
    <input type="text" name="name" value="{{risk.name}}" placeholder="{{localize 'SVNSEA2E.RiskNamePlaceholder'}}" />
  </div>

  <div class="rb-field">
    <label>{{localize "SVNSEA2E.RiskSituation"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.RiskSituationHint'}}"></i></label>
    <textarea name="situation" rows="2" placeholder="{{localize 'SVNSEA2E.RiskSituationPlaceholder'}}">{{risk.situation}}</textarea>
  </div>

  {{!-- Scene — the Heroes involved + each one's Trait+Skill (Approach) --}}
  <div class="rb-section rb-scene">
    <div class="rb-head">
      <h3><i class="fas fa-users"></i> {{localize "SVNSEA2E.RiskScene"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.RiskSceneHint'}}"></i></h3>
      {{#if hasActors}}<a class="rb-add-participant"><i class="fas fa-plus"></i> {{localize "SVNSEA2E.RiskAddHero"}}</a>{{/if}}
    </div>
    <p class="rb-scene-note">{{localize "SVNSEA2E.RiskSceneIntro"}}</p>
    {{#if hasActors}}
      {{#each participants as |p i|}}
        <div class="rb-participant rb-row" data-i="{{i}}">
          <select class="rb-p-actor" aria-label="{{localize 'SVNSEA2E.RiskHero'}}">
            <option value="">{{localize "SVNSEA2E.RiskChooseHero"}}</option>
            {{#each p.actors}}<option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>{{/each}}
          </select>
          <select class="rb-p-trait" aria-label="{{localize 'SVNSEA2E.Trait'}}">
            <option value="">{{localize "SVNSEA2E.Trait"}}</option>
            {{#each p.traits}}<option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
          </select>
          <select class="rb-p-skill" aria-label="{{localize 'SVNSEA2E.Skill'}}">
            <option value="">{{localize "SVNSEA2E.Skill"}}</option>
            {{#each p.skills}}<option value="{{key}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
          </select>
          <span class="rb-p-pool" data-tooltip="{{localize 'SVNSEA2E.RiskPoolHint'}}">{{#if p.pool}}{{p.pool}}d10{{else}}—{{/if}}</span>
          <a class="rb-remove-participant" data-i="{{i}}" title="{{localize 'SVNSEA2E.Remove'}}"><i class="fas fa-times"></i></a>
        </div>
      {{else}}
        <p class="rb-empty">{{localize "SVNSEA2E.RiskNoHeroes"}}</p>
      {{/each}}
    {{else}}
      <p class="rb-empty">{{localize "SVNSEA2E.RiskNoPcActors"}}</p>
    {{/if}}
  </div>

  {{!-- Consequences --}}
  <div class="rb-section">
    <div class="rb-head">
      <h3><i class="fas fa-skull-crossbones"></i> {{localize "SVNSEA2E.RiskConsequences"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.RiskConsequencesHint'}}"></i></h3>
      <span class="rb-head-ctl">
        <select class="rb-example-pick" data-kind="consequence" data-tooltip="{{localize 'SVNSEA2E.RiskExamplesHint'}}">
          <option value="">{{localize "SVNSEA2E.RiskInsertExample"}}</option>
          {{#each exampleConsequences}}<optgroup label="{{group}}">{{#each items}}<option value="{{text}}">{{text}}</option>{{/each}}</optgroup>{{/each}}
        </select>
        <a class="rb-add" data-kind="consequence"><i class="fas fa-plus"></i> {{localize "SVNSEA2E.AddConsequence"}}</a>
      </span>
    </div>
    {{#each risk.consequences as |c i|}}
      <div class="rb-row" data-kind="consequence" data-i="{{i}}">
        <input type="text" class="rb-desc" value="{{c.desc}}" placeholder="{{localize 'SVNSEA2E.RiskDescPlaceholder'}}" />
        <label class="rb-mini" data-tooltip="{{localize 'SVNSEA2E.RiskRaisesHint'}}">{{localize "SVNSEA2E.RiskRaises"}}<input type="number" class="rb-cost" value="{{c.cost}}" min="0" /></label>
        <label class="rb-mini" data-tooltip="{{localize 'SVNSEA2E.RiskTimeLimitHint'}}">{{localize "SVNSEA2E.RiskTimeLimit"}}<input type="number" class="rb-time" value="{{c.time}}" min="0" placeholder="—" /></label>
        <a class="rb-remove" data-kind="consequence" data-i="{{i}}" title="{{localize 'SVNSEA2E.Remove'}}"><i class="fas fa-times"></i></a>
      </div>
    {{else}}
      <p class="rb-empty">{{localize "SVNSEA2E.RiskNoConsequences"}}</p>
    {{/each}}
  </div>

  {{!-- Opportunities --}}
  <div class="rb-section">
    <div class="rb-head">
      <h3><i class="fas fa-hand-sparkles"></i> {{localize "SVNSEA2E.RiskOpportunities"}}<i class="fas fa-circle-info info-dot" data-tooltip="{{localize 'SVNSEA2E.RiskOpportunitiesHint'}}"></i></h3>
      <span class="rb-head-ctl">
        <select class="rb-example-pick" data-kind="opportunity" data-tooltip="{{localize 'SVNSEA2E.RiskExamplesHint'}}">
          <option value="">{{localize "SVNSEA2E.RiskInsertExample"}}</option>
          {{#each exampleOpportunities}}<optgroup label="{{group}}">{{#each items}}<option value="{{text}}">{{text}}</option>{{/each}}</optgroup>{{/each}}
        </select>
        <a class="rb-add" data-kind="opportunity"><i class="fas fa-plus"></i> {{localize "SVNSEA2E.AddOpportunity"}}</a>
      </span>
    </div>
    {{#each risk.opportunities as |o i|}}
      <div class="rb-row" data-kind="opportunity" data-i="{{i}}">
        <input type="text" class="rb-desc" value="{{o.desc}}" placeholder="{{localize 'SVNSEA2E.RiskOppPlaceholder'}}" />
        <label class="rb-mini" data-tooltip="{{localize 'SVNSEA2E.RiskRaisesHint'}}">{{localize "SVNSEA2E.RiskRaises"}}<input type="number" class="rb-cost" value="{{o.cost}}" min="0" /></label>
        <label class="rb-mini" data-tooltip="{{localize 'SVNSEA2E.RiskTimeLimitHint'}}">{{localize "SVNSEA2E.RiskTimeLimit"}}<input type="number" class="rb-time" value="{{o.time}}" min="0" placeholder="—" /></label>
        <a class="rb-remove" data-kind="opportunity" data-i="{{i}}" title="{{localize 'SVNSEA2E.Remove'}}"><i class="fas fa-times"></i></a>
      </div>
    {{else}}
      <p class="rb-empty">{{localize "SVNSEA2E.RiskNoOpportunities"}}</p>
    {{/each}}
  </div>

  <div class="rb-example">
    <span class="rx-lbl">{{localize "SVNSEA2E.RiskExampleTitle"}}</span> {{localize "SVNSEA2E.RiskExample"}}
  </div>

  <div class="rb-actions">
    <button type="button" class="rb-new" data-tooltip="{{localize 'SVNSEA2E.RiskNewHint'}}"><i class="fas fa-file"></i> {{localize "SVNSEA2E.RiskNew"}}</button>
    <button type="button" class="rb-save"><i class="fas fa-floppy-disk"></i> {{localize "SVNSEA2E.RiskSave"}}</button>
    <button type="button" class="rb-post primary"><i class="fas fa-comment"></i> {{localize "SVNSEA2E.PostRisk"}}</button>
  </div>
</form>
